# OpenClaw Gateway Configuration Example
# Copy this to .env and update with your values

# Gateway Token - for local development
# Used for authentication when connecting to gateway
OPENCLAW_GATEWAY_TOKEN=dev-openclaw-token-18789

# Gateway Connection Details
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789

# Onboard Server Configuration
PORT=18788
GATEWAY_PORT=18789

# OpenClaw Node Environment
NODE_ENV=development

# Optional: API Keys for onboarding (Uncomment to use)
# ANTHROPIC_API_KEY=your-anthropic-key-here
# GOOGLE_GEMINI_API_KEY=your-gemini-key-here
# OPENAI_API_KEY=your-openai-key-here
