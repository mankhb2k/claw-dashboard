{
  "name": "openclaw",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "ui:dev": "npm --prefix control-ui run dev",
    "ui:build": "npm --prefix control-ui run build",
    "control-ui:build": "npm run ui:build",
    "gateway:onboard": "openclaw onboard --mode local",
    "onboard": "node onboard-server.js",
    "gateway:run": "openclaw gateway run --bind loopback --port 18789",
    "gateway:run:lan": "openclaw gateway run --bind lan --port 18789",
    "dev": "npm run gateway:run",
    "dev:with-ui": "npm run ui:build && npm run gateway:run",
    "dashboard:url": "openclaw dashboard --no-open",
    "docker:build:control-ui": "docker build -t openclaw-control-ui:local -f Dockerfile.control-ui .",
    "docker:run:control-ui": "docker run --rm --name openclaw-control-ui -p 18789:18789 -e OPENCLAW_GATEWAY_TOKEN=dev-openclaw-token-18789 openclaw-control-ui:local"
  },
