{
  "name": "aucobot-mcp-hub",
  "version": "0.0.0",
  "private": true,
  "description": "First-party MCP packages for AucoBot (@aucobot/mcp-*)",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "pack:all": "pnpm -r exec npm pack",
    "publish:core": "pnpm --filter @aucobot/mcp-core publish --access public --no-git-checks",
    "publish:drive": "pnpm --filter @aucobot/mcp-google-drive publish --access public --no-git-checks",
    "publish:all": "pnpm run publish:core && pnpm run publish:drive"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
