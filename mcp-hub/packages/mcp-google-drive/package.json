{
  "name": "@aucobot/mcp-google-drive",
  "version": "0.1.0",
  "description": "AucoBot first-party MCP server for Google Drive (stdio)",
  "type": "module",
  "bin": {
    "aucobot-mcp-google-drive": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aucobot/mcp-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "googleapis": "^173.0.0",
    "pdf-lib": "^1.17.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  }
}
