generator client {
  provider = "prisma-client-js"
  // Local output — avoid IDE resolving stale @prisma/client from sibling packages (e.g. backend/)
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Self-host: unique username only (no email).
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  name              String?
  avatarUrl         String?  @map("avatar_url")
  avatarMimeType    String?  @map("avatar_mime_type")
  avatarData        Bytes?   @map("avatar_data")
  avatarStorageKey  String?  @map("avatar_storage_key")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  /// IANA timezone for usage analytics (e.g. UTC, Asia/Ho_Chi_Minh).
  analyticsTimezone String   @default("UTC") @map("analytics_timezone")

  refreshTokens    RefreshToken[]
  projects         Project[]
  modelUsageEvents ModelUsageEvent[]
  chatAttachments  ChatAttachment[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// OSS: one user ≈ one project; shared gateway via env; token also stored on project for UI.
model Project {
  id           String        @id @default(cuid())
  userId       String        @unique @map("user_id")
  displayName  String        @map("display_name")
  subdomain    String        @unique
  gatewayToken String?       @map("gateway_token")
  collaborationEnabled     Boolean @default(false) @map("collaboration_enabled")
  collaborationMemberSlugs Json    @default("[]") @map("collaboration_member_slugs")
  heartbeatEnabled         Boolean @default(false) @map("heartbeat_enabled")
  heartbeatEvery           String  @default("30m") @map("heartbeat_every")
  heartbeatMd              String? @map("heartbeat_md") @db.Text
  sandboxDefaultEnabled    Boolean @default(false) @map("sandbox_default_enabled")
  sandboxDefaultMode       String  @default("all") @map("sandbox_default_mode")
  sandboxExemptAgentSlugs  Json    @default("[]") @map("sandbox_exempt_agent_slugs")
  sandboxAppliedAgentSlugs Json    @default("[]") @map("sandbox_applied_agent_slugs")
  execAskPolicy            String  @default("on-miss") @map("exec_ask_policy")
  execSafeBins             Json    @default("[]") @map("exec_safe_bins")
  execTimeoutSec           Int     @default(1800) @map("exec_timeout_sec")
  status       ProjectStatus @default(CREATING)
  errorMessage String?       @map("error_message")
  lastActiveAt DateTime      @default(now()) @map("last_active_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectProviderKeys  ProjectProviderKey[]
  projectProviderModels ProjectProviderModel[]
  projectSkills       ProjectSkill[]
  projectAgents       ProjectAgent[]
  projectConnectors   ProjectConnector[]
  projectChannels     ProjectChannel[]
  nodeInvites         NodeInvite[]
  modelUsageEvents    ModelUsageEvent[]
  chatAttachments     ChatAttachment[]

  @@map("projects")
}

/// Short-lived pairing code for OpenClaw Node desktop app (Phase 2).
model NodeInvite {
  id         String    @id @default(cuid())
  projectId  String    @map("project_id")
  codeHash   String    @unique @map("code_hash")
  codePrefix String    @map("code_prefix")
  label      String?
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expiresAt])
  @@map("node_invites")
}

model ProjectConnector {
  id               String                    @id @default(cuid())
  projectId        String                    @map("project_id")
  connectorSlug    String                    @map("connector_slug")
  displayName      String                    @map("display_name")
  enabled          Boolean                   @default(false)
  connectionStatus ConnectorConnectionStatus @default(DISCONNECTED) @map("connection_status")
  config           Json                      @default("{}")
  lastTestedAt     DateTime?                 @map("last_tested_at")
  lastError        String?                   @map("last_error")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  project Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secrets ProjectConnectorSecret[]

  @@unique([projectId, connectorSlug])
  @@index([projectId])
  @@map("project_connectors")
}

model ProjectConnectorSecret {
  id                 String   @id @default(cuid())
  projectConnectorId String   @map("project_connector_id")
  secretKey          String   @map("secret_key")
  ciphertext         String   @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  projectConnector ProjectConnector @relation(fields: [projectConnectorId], references: [id], onDelete: Cascade)

  @@unique([projectConnectorId, secretKey])
  @@map("project_connector_secrets")
}

enum ConnectorConnectionStatus {
  DISCONNECTED
  CONNECTED
  ERROR
  NEEDS_REAUTH
}

model AgentTemplate {
  slug              String   @id
  name              String
  description       String   @db.Text
  avatar            String
  vibe              String
  defaultModel      String   @map("default_model")
  toolsProfile      String   @map("tools_profile")
  sandboxEnabled    Boolean  @default(false) @map("sandbox_enabled")
  bootstrapIdentity String   @map("bootstrap_identity") @db.Text
  bootstrapSoul     String   @map("bootstrap_soul") @db.Text
  bootstrapAgents   String   @map("bootstrap_agents") @db.Text
  sortOrder         Int      @default(0) @map("sort_order")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("agent_templates")
}

model ProjectAgent {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  slug          String
  name          String
  description   String    @db.Text
  avatar        String
  formData      Json      @map("form_data")
  enabled       Boolean   @default(false)
  isDefault     Boolean   @default(false) @map("is_default")
  heartbeatMode   String  @default("off") @map("heartbeat_mode")
  heartbeatEvery  String? @map("heartbeat_every")
  heartbeatMd     String? @map("heartbeat_md") @db.Text
  lastSyncedAt  DateTime? @map("last_synced_at")
  lastSyncError String?   @map("last_sync_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  project  Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  apiKeys  ProjectAgentApiKey[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("project_agents")
}

/// REST/widget access tokens for a single agent (`sk-claw-…`). Plaintext shown once on create; only hash + prefix stored.
model ProjectAgentApiKey {
  id             String    @id @default(cuid())
  projectAgentId String    @map("project_agent_id")
  label          String
  tokenPrefix    String    @map("token_prefix")
  tokenHash      String    @unique @map("token_hash")
  lastUsedAt     DateTime? @map("last_used_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  projectAgent ProjectAgent @relation(fields: [projectAgentId], references: [id], onDelete: Cascade)

  @@index([projectAgentId])
  @@index([projectAgentId, revokedAt])
  @@map("project_agent_api_keys")
}

model ProjectSkill {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  slug          String
  name          String
  description   String    @db.Text
  heading       String?
  bodyMarkdown  String    @default("") @map("body_markdown") @db.Text
  enabled       Boolean   @default(false)
  lastSyncedAt  DateTime? @map("last_synced_at")
  lastSyncError String?   @map("last_sync_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("project_skills")
}

model ProjectProviderKey {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  providerId   String    @map("provider_id")
  envKey       String    @map("env_key")
  label        String?
  ciphertext   String    @db.Text
  enabled      Boolean   @default(true)
  defaultModel String?   @map("default_model")
  lastTestedAt DateTime? @map("last_tested_at")
  lastTestOk   Boolean?  @map("last_test_ok")
  lastError    String?   @map("last_error")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, providerId])
  @@index([projectId])
  @@map("project_provider_keys")
}

/// User-managed model ref for AI Provider (proxy) keys — e.g. openrouter/auto.
model ProjectProviderModel {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  providerId  String   @map("provider_id")
  openclawId  String   @map("openclaw_id")
  displayName String?  @map("display_name")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, providerId, openclawId])
  @@index([projectId, providerId])
  @@map("project_provider_models")
}

/// OpenClaw messaging channel on a project (telegram, discord, zalo, …). MVP: one account per channelId.
model ProjectChannel {
  id               String                  @id @default(cuid())
  projectId        String                  @map("project_id")
  channelId        String                  @map("channel_id")
  enabled          Boolean                 @default(false)
  connectionStatus ChannelConnectionStatus @default(DISCONNECTED) @map("connection_status")
  config           Json                    @default("{}")
  lastError        String?                 @map("last_error")
  lastTestedAt     DateTime?               @map("last_tested_at")
  lastSyncedAt     DateTime?               @map("last_synced_at")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  project Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secrets ProjectChannelSecret[]

  @@unique([projectId, channelId])
  @@index([projectId])
  @@map("project_channels")
}

model ProjectChannelSecret {
  id               String   @id @default(cuid())
  projectChannelId String   @map("project_channel_id")
  secretKey        String   @map("secret_key")
  ciphertext       String   @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  projectChannel ProjectChannel @relation(fields: [projectChannelId], references: [id], onDelete: Cascade)

  @@unique([projectChannelId, secretKey])
  @@map("project_channel_secrets")
}

enum ChannelConnectionStatus {
  DISCONNECTED
  CONFIGURED
  CONNECTED
  NEEDS_REAUTH
  ERROR
}

enum ProjectStatus {
  CREATING
  RUNNING
  ERROR
}

enum UsageStatus {
  SUCCESS
  FAILED
  CANCELLED
}

enum UsageSource {
  CHAT_UI
  CHANNEL
  CRON
  API_KEY
  HEARTBEAT
  OTHER
}

/// Append-only LLM call telemetry for overview analytics (1 row = 1 model completion).
model ModelUsageEvent {
  id           String       @id @default(cuid())
  projectId    String       @map("project_id")
  userId       String       @map("user_id")
  agentSlug    String?      @map("agent_slug")
  providerId   String?      @map("provider_id")
  modelId      String       @map("model_id")
  inputTokens  Int          @default(0) @map("input_tokens")
  outputTokens Int          @default(0) @map("output_tokens")
  costUsd      Decimal      @default(0) @map("cost_usd") @db.Decimal(12, 6)
  status       UsageStatus
  latencyMs    Int?         @map("latency_ms")
  source       UsageSource
  externalId   String?      @map("external_id")
  metadata     Json         @default("{}")
  createdAt    DateTime     @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalId])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("model_usage_events")
}

/// Per-model token pricing (USD per 1M tokens) — used when recording cost_usd on events.
model ModelPricing {
  providerId     String   @map("provider_id")
  modelId        String   @map("model_id")
  inputPer1MUsd  Decimal  @map("input_per_1m_usd") @db.Decimal(10, 6)
  outputPer1MUsd Decimal  @map("output_per_1m_usd") @db.Decimal(10, 6)
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@id([providerId, modelId])
  @@map("model_pricing")
}

enum ChatAttachmentKind {
  IMAGE
  DOCUMENT
}

enum ChatAttachmentStatus {
  PENDING
  LINKED
  DELETED
}

/// Chat file metadata — bytes on disk (OSS) or R2 (Cloud); never blob in DB.
model ChatAttachment {
  id           String               @id @default(cuid())
  projectId    String               @map("project_id")
  userId       String               @map("user_id")
  sessionKey   String?              @map("session_key")
  kind         ChatAttachmentKind
  mimeType     String               @map("mime_type")
  originalName String               @map("original_name")
  sizeBytes    Int                  @map("size_bytes")
  storagePath  String?              @map("storage_path")
  storageKey   String?              @map("storage_key")
  status       ChatAttachmentStatus @default(PENDING)
  linkedRunId  String?              @map("linked_run_id")
  expiresAt    DateTime?            @map("expires_at")
  createdAt    DateTime             @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([projectId, userId])
  @@index([expiresAt])
  @@map("chat_attachments")
}
