# AucoBot — single env file for local dev (Model A)
# Setup:  cp .env.example .env   then edit values below.
# Optional overrides: .env.local (gitignored, merged on top)
#
# Production: set the same variable NAMES in Vercel (web) / Railway (api).
# Docker compose: deploy/.env (separate profile — service hostnames).

# =============================================================================
# Shared — API + Web (keep JWT / gateway token in sync across stack)
# =============================================================================
RUNTIME_MODE=oss
JWT_SECRET=change-me-to-long-random-string
JWT_ACCESS_SECONDS=900
JWT_REFRESH_DAYS=7

OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=change-me-gateway-token

# Web (browser) — OSS Control UI link in Settings (optional; defaults to OPENCLAW_GATEWAY_URL above)
# NEXT_PUBLIC_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# NEXT_PUBLIC_OPENCLAW_CONTROL_UI_BASE_PATH=

# =============================================================================
# API only — Nest @aucobot/api, Prisma migrate/seed, packages/*
# =============================================================================
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/openclaw

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
PORT=3001
APP_DOMAIN=localhost
COOKIE_SECURE=false

OPENCLAW_DATA_ROOT=./data/projects
OPENCLAW_HEALTH_INTERVAL_MS=2000
OPENCLAW_HEALTH_FETCH_TIMEOUT_MS=3000
OPENCLAW_SPAWN_TIMEOUT_MS=60000

# OPENCLAW_GATEWAY_MIN_PROTOCOL=3
# OPENCLAW_GATEWAY_MAX_PROTOCOL=4

# Cloud hosted (RUNTIME_MODE=cloud) — spawn 1 container / project
# OPENCLAW_IMAGE=openclaw-worker:1.0.2

# User profile avatars (POST /api/users/me/avatar, multipart field "file")
# OSS (RUNTIME_MODE=oss): stored in Postgres (avatar_data) — no extra vars below.
# Web uses relative path /api/users/me/avatar — keep BACKEND_URL correct for absolute URLs if needed.

# Cloud user avatars (S3-compatible — R2, MinIO, AWS) — only when RUNTIME_MODE=cloud
# AVATAR_S3_BUCKET=aucobot-avatars
# AVATAR_S3_ACCESS_KEY_ID=
# AVATAR_S3_SECRET_ACCESS_KEY=
# AVATAR_S3_REGION=auto
# AVATAR_S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# AVATAR_S3_FORCE_PATH_STYLE=true
# AVATAR_PUBLIC_BASE_URL=https://cdn.example.com/aucobot-avatars

# Cloud chat attachments (private R2 bucket) — only when RUNTIME_MODE=cloud
# CHAT_ATTACHMENT_S3_BUCKET=aucobot-chat-attachments
# CHAT_ATTACHMENT_S3_ACCESS_KEY_ID=
# CHAT_ATTACHMENT_S3_SECRET_ACCESS_KEY=
# CHAT_ATTACHMENT_S3_REGION=auto
# CHAT_ATTACHMENT_S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# CHAT_ATTACHMENT_S3_FORCE_PATH_STYLE=true

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/connectors/oauth/callback

SELF_HOST_USER_USERNAME=admin
SELF_HOST_USER_PASSWORD=admin123

# SKILL_AI_EDITOR_TIMEOUT_MS=120000
# SKILL_AI_EDITOR_MAX_OUTPUT_TOKENS=8192

# ClawHub skill store (Browser Store) — public read API
# CLAWHUB_API_BASE=https://clawhub.ai

# =============================================================================
# Web only — Next.js @aucobot/web (NEXT_PUBLIC_* is exposed to the browser)
# =============================================================================
NEXT_PUBLIC_MOCK_API=false
NEXT_PUBLIC_RUNTIME_MODE=oss
# Empty = same-origin via Next rewrite /api → Nest (recommended local dev)
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-side only (Next middleware / RSC) — Docker compose uses service name
# API_INTERNAL_URL=http://api:3001

# =============================================================================
# Split deploy (Vercel + Railway) — uncomment and use on each platform
# =============================================================================
# FRONTEND_URL=https://app.example.com
# NEXT_PUBLIC_API_URL=https://api.example.com
# COOKIE_SECURE=true
