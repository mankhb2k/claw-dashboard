# false = đăng nhập/đăng xuất thật qua backend (khuyến nghị)
# true = mock API — logout chỉ xóa state trong RAM, không có cookie JWT
NEXT_PUBLIC_MOCK_API=false
# Để trống = same-origin qua Next rewrite /api → Nest (cookie auth hoạt động đúng).
# Chỉ set khi API ở domain/port khác (vd. https://api.example.com).
# NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_RUNTIME_MODE=oss

# Connect (Google Drive / Calendar): cấu hình OAuth trên backend — xem backend/.env.example
