DATABASE_URL=postgresql://postgres:password@localhost:5432/openclaw

JWT_SECRET=change-me-to-long-random-string
JWT_ACCESS_SECONDS=900
JWT_REFRESH_DAYS=7

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# --- OSS self-host (default) ---
RUNTIME_MODE=oss

# Gateway openclaw-worker :18789
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Must match token on gateway container and openclaw.json (sync from API)
OPENCLAW_GATEWAY_TOKEN=change-me-gateway-token
# WebSocket connect negotiation (openclaw-worker:1.0.2 uses protocol v3)
# OPENCLAW_GATEWAY_MIN_PROTOCOL=3
# OPENCLAW_GATEWAY_MAX_PROTOCOL=4
OPENCLAW_DATA_ROOT=./data/projects

# --- Cloud hosted (RUNTIME_MODE=cloud) — spawn 1 container / project ---
# RUNTIME_MODE=cloud
# OPENCLAW_IMAGE=openclaw-worker:1.0.2
# OPENCLAW_SPAWN_TIMEOUT_MS=60000

OPENCLAW_HEALTH_INTERVAL_MS=2000
OPENCLAW_HEALTH_FETCH_TIMEOUT_MS=3000
OPENCLAW_SPAWN_TIMEOUT_MS=60000

APP_DOMAIN=localhost

# Connect — Google Drive & Google Calendar
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/connectors/oauth/callback

# Self-host default user
SELF_HOST_USER_USERNAME=admin
# SELF_HOST_USER_LOGIN=admin  # legacy alias
SELF_HOST_USER_PASSWORD=admin123

# Skill AI editor (LLM chat on skill editor page)
# SKILL_AI_EDITOR_TIMEOUT_MS=120000
# SKILL_AI_EDITOR_MAX_OUTPUT_TOKENS=8192
