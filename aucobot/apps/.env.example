# AucoBot — single env file for local dev (Model A)
# Setup:  cd aucobot/apps && cp .env.example .env   then edit values below.
# Optional overrides: .env.local (gitignored, merged on top)
#
# Production: set the same variable NAMES in Vercel (web) / Railway (api).
# Docker compose: deploy/.env (separate profile — service hostnames).

# =============================================================================
# Shared — API + Web (keep JWT / gateway token in sync across stack)
# =============================================================================
# Self-host mode (default) — shared OpenClaw gateway on :18789
RUNTIME_MODE=oss
JWT_SECRET=change-me-to-long-random-string
JWT_ACCESS_SECONDS=900
JWT_REFRESH_DAYS=7

OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=change-me-gateway-token

# Web (browser) — OSS Control UI link in Settings (optional; defaults to OPENCLAW_GATEWAY_URL above)
# NEXT_PUBLIC_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# NEXT_PUBLIC_OPENCLAW_CONTROL_UI_BASE_PATH=

# =============================================================================
# API only — Nest @aucobot/api, Prisma migrate/seed, packages/*
# =============================================================================
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/openclaw

FRONTEND_URL=http://localhost:8386
BACKEND_URL=http://localhost:8387
PORT=8387
APP_DOMAIN=localhost
COOKIE_SECURE=false

OPENCLAW_DATA_ROOT=./data/projects
OPENCLAW_HEALTH_INTERVAL_MS=2000
OPENCLAW_HEALTH_FETCH_TIMEOUT_MS=3000
OPENCLAW_SPAWN_TIMEOUT_MS=60000

# OPENCLAW_GATEWAY_MIN_PROTOCOL=4
# OPENCLAW_GATEWAY_MAX_PROTOCOL=4

# User profile avatars (POST /api/users/me/avatar, multipart field "file")
# Always local in apps/api: Postgres avatar_data (see rule.md §1.13 — not RUNTIME_MODE).

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8387/api/connectors/oauth/callback

# Hosted MCP (sibling repo ../mcp on :8388) — sync connectors to HTTP MCP instead of npx on gateway
# Docker compose: use deploy/.env → AUCOMCP_BASE_URL=http://mcp:8388
MCP_SERVICE_SECRET=change-me-mcp-service-secret
AUCOMCP_BASE_URL=http://127.0.0.1:8388

SELF_HOST_USER_USERNAME=admin
SELF_HOST_USER_PASSWORD=admin123

# SKILL_AI_EDITOR_TIMEOUT_MS=120000
# SKILL_AI_EDITOR_MAX_OUTPUT_TOKENS=8192

# ClawHub skill store (Browser Store) — public read API
# CLAWHUB_API_BASE=https://clawhub.ai

# =============================================================================
# Web only — Next.js @aucobot/web (NEXT_PUBLIC_* is exposed to the browser)
# =============================================================================
NEXT_PUBLIC_MOCK_API=false
NEXT_PUBLIC_RUNTIME_MODE=oss
# Empty = same-origin via Next rewrite /api → Nest (recommended local dev)
# NEXT_PUBLIC_API_URL=http://localhost:8387

# Logoship CDN — connector icons only (channels / AI models / brand use /public)
# NEXT_PUBLIC_LOGOSHIP_CDN_BASE=https://cdn.jsdelivr.net/gh/logoship/logoship@latest

# Server-side only (Next middleware / RSC) — Docker compose uses service name
# API_INTERNAL_URL=http://api:8387

# =============================================================================
# Split deploy (Vercel + Railway) — uncomment and use on each platform
# =============================================================================
# FRONTEND_URL=https://app.example.com
# NEXT_PUBLIC_API_URL=https://api.example.com
# COOKIE_SECURE=true
