{
  "name": "aucobot",
  "private": true,
  "description": "AucoBot monorepo — OSS-first control plane + OpenClaw gateway",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@aucobot/api --filter=@aucobot/web",
    "build": "turbo run build",
    "build:packages": "pnpm db:generate && pnpm --filter @aucobot/shared --filter @aucobot/database --filter @aucobot/runtime-contracts --filter @aucobot/workspace-sync --filter @aucobot/runtime-oss --filter @aucobot/control-plane-core --filter @aucobot/clawhub-client run build",
    "lint": "turbo run lint",
    "dev:db": "docker compose -f deploy/docker-compose.postgres.dev.yml up -d --remove-orphans",
    "dev:db:down": "docker compose -f deploy/docker-compose.postgres.dev.yml down --remove-orphans",
    "dev:runtime": "docker compose -f deploy/docker-compose.runtime.yml --env-file deploy/.env.gateway up -d --remove-orphans",
    "dev:runtime:pull": "docker compose -f deploy/docker-compose.runtime.yml --env-file deploy/.env.gateway pull gateway",
    "dev:runtime:down": "docker compose -f deploy/docker-compose.runtime.yml --env-file deploy/.env.gateway down --remove-orphans",
    "dev:runtime:logs": "docker compose -f deploy/docker-compose.runtime.yml --env-file deploy/.env.gateway logs -f postgres gateway",
    "dev:stack": "docker compose -f deploy/docker-compose.yml up",
    "db:generate": "pnpm --filter @aucobot/database db:generate",
    "db:migrate": "pnpm --filter @aucobot/database db:migrate",
    "db:seed": "pnpm --filter @aucobot/database db:seed",
    "postinstall": "pnpm db:generate && pnpm --filter @aucobot/runtime-contracts --filter @aucobot/control-plane-core --filter @aucobot/clawhub-client run build"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  }
}
