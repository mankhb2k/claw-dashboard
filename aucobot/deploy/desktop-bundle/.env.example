# Sao chép file này thành .env (Setup-AucoBot.bat làm tự động lần đầu).
# Chỉ cần sửa 3 dòng nếu dùng máy cá nhân; để mặc định vẫn chạy được để thử.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=aucobot-local-postgres
POSTGRES_DB=openclaw

OPENCLAW_GATEWAY_TOKEN=change-token-9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b
OPENCLAW_IMAGE=alpine/openclaw:latest
# OSS uses fixed disk folder default/ — no OSS_PROJECT_ID needed.

JWT_SECRET=aucobot-local-jwt-change-in-production
FRONTEND_URL=http://localhost:8386
APP_DOMAIN=localhost
COOKIE_SECURE=false

API_INTERNAL_URL=http://api:8387

SELF_HOST_USER_USERNAME=admin
SELF_HOST_USER_PASSWORD=admin123

# Pin image tag from Docker Hub (https://hub.docker.com/u/aucobot)
AUCOBOT_IMAGE_TAG=latest

# OAuth relay — bật nếu có dịch vụ relay (kết nối Google/GitHub 1 click)
# OAUTH_MODE=relay
# OAUTH_RELAY_URL=https://oauth.aucobot.com
# OAUTH_RELAY_API_SECRET=
