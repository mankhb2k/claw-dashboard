# Copy to deploy/.env before: docker compose -f deploy/docker-compose.yml up -d

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=openclaw

# --- Gateway (official release: alpine/openclaw on Docker Hub) ---
OPENCLAW_IMAGE=alpine/openclaw:latest
OPENCLAW_GATEWAY_TOKEN=change-me-gateway-token

# API (root) + gateway (uid 1000) share openclaw_data — keep in sync with gateway image user.
OPENCLAW_RUNTIME_UID=1000
OPENCLAW_RUNTIME_GID=1000

# Optional: pin one project folder under openclaw_data volume.
# Leave empty to auto-pick the first project with openclaw.json.
OSS_PROJECT_ID=

# --- API (NestJS) ---
JWT_SECRET=change-me-to-long-random-string
JWT_ACCESS_SECONDS=900
JWT_REFRESH_DAYS=7
FRONTEND_URL=http://localhost:8386
APP_DOMAIN=localhost
COOKIE_SECURE=false

# Docker compose: Next.js middleware calls api by service name
API_INTERNAL_URL=http://api:8387

SELF_HOST_USER_USERNAME=admin
SELF_HOST_USER_PASSWORD=change-me-admin-password

# --- Web (Next.js build args) ---
# Leave empty in Docker so the browser uses http://localhost:8386/api (rewrite → api).
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_RUNTIME_MODE=oss
NEXT_PUBLIC_MOCK_API=false

# Google connectors (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8387/api/connectors/oauth/callback

# Hosted MCP (aucomcp) — optional; when set, connectors sync to HTTP MCP instead of npx
MCP_SERVICE_SECRET=change-me-mcp-service-secret
AUCOMCP_BASE_URL=http://mcp:8388

# --- Docker Hub — pull pre-built images (default; mcp is pull-only) ---
# https://hub.docker.com/u/aucobot
# AUCOBOT_IMAGE_TAG=latest
# AUCOBOT_API_IMAGE=docker.io/aucobot/api:latest
# AUCOBOT_WEB_IMAGE=docker.io/aucobot/web:latest
# AUCOBOT_MCP_IMAGE=docker.io/aucobot/mcp:latest

# Skill AI editor (optional — defaults in code)
# SKILL_AI_EDITOR_TIMEOUT_MS=120000
# SKILL_AI_EDITOR_MAX_OUTPUT_TOKENS=8192
