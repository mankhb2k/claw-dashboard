# Redis Configuration
REDIS_URL=redis://default:your-password@redis:6379
# OR individual vars:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password

# Control Plane (Backend)
CONTROL_PLANE_URL=https://api.openclaw.ai
VPS_WORKER_SECRET=your-vps-worker-secret

# Heavy Tasks Configuration
DATA_DIR=/data/users
CONCURRENT_JOBS=3
MAX_OUTPUT_SIZE=500000000  # 500MB

# Tool Timeouts (seconds)
FFMPEG_TIMEOUT=300      # 5 minutes
PLAYWRIGHT_TIMEOUT=120  # 2 minutes

# Server
PORT=3003
DEBUG=false

# Optional API Keys (for real implementations)
OPENAI_API_KEY=
GOOGLE_TTS_API_KEY=
GOOGLE_STT_API_KEY=
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# Node
NODE_ENV=development
