{
  "name": "@claw-dashboard/workspace-sync",
  "version": "0.0.0",
  "private": true,
  "description": "openclaw.json merge, agent compile, skills markdown, connector MCP files",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./agent-workspace-compile": {
      "types": "./dist/agents/agent-workspace-compile.d.ts",
      "default": "./dist/agents/agent-workspace-compile.js"
    },
    "./skill-markdown": {
      "types": "./dist/skills/skill-markdown.d.ts",
      "default": "./dist/skills/skill-markdown.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --import tsx --test src/**/*.spec.ts"
  },
  "dependencies": {
    "@claw-dashboard/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3"
  }
}
