# Redis Configuration
REDIS_URL=redis://default:your-password@redis:6379
# OR individual vars:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password

# Control Plane (Backend)
CONTROL_PLANE_URL=https://api.openclaw.ai
VPS_WORKER_SECRET=your-vps-worker-secret

# VPS Configuration
VPS_NODE_ID=vps-1
OPENCLAW_IMAGE=openclaw-gateway:latest
DATA_DIR=/data/users

# Server
PORT=3002
DEBUG=false

# Node
NODE_ENV=development
