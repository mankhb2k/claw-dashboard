# ═══════════════════════════════════════════════════════════════════════════════
# VPS Worker Environment Configuration
# Copy to .env and update values before running: docker-compose up -d
# ═══════════════════════════════════════════════════════════════════════════════

# ─── CONTROL PLANE (Backend API on Railway) ───────────────────────────────────
# URL của Backend API (Railway public URL hoặc custom domain)
CONTROL_PLANE_URL=https://api.openclaw.ai
# hoặc: https://your-railway-project.up.railway.app

# Secret token để authenticate callback từ VPS Worker → Backend
# Phải match giá trị ở Backend .env (VPS_WORKER_SECRET)
VPS_WORKER_SECRET=your-super-secret-key-change-this

# ─── REDIS (Railway Managed) ───────────────────────────────────────────────────
# Railway Redis connection string
# Format: redis://default:PASSWORD@HOST:PORT
# Lấy từ Railway Dashboard → Redis → Connect
REDIS_URL=redis://default:your-redis-password@redis-host.railway.app:6379

# ─── VPS NODE IDENTIFICATION ───────────────────────────────────────────────────
# Tên/ID của VPS này (dùng cho multi-VPS scale)
# Ví dụ: vps-1, vps-2, worker-sg, worker-us, etc.
VPS_NODE_ID=vps-1

# ─── DOCKER IMAGE CONFIGURATION ───────────────────────────────────────────────
# User container image (openclaw-gateway)
# Khi update, chỉ cần đổi tag này + restart vps-worker service
OPENCLAW_IMAGE=mankhb2k/clawsaas-worker:latest
# hoặc version cụ thể: mankhb2k/clawsaas-worker:2026.5.0

# VPS Worker image tag (docker-compose pull)
VPS_WORKER_TAG=latest
# hoặc version cụ thể: VPS_WORKER_TAG=2026.5.0

# ─── STORAGE CONFIGURATION ───────────────────────────────────────────────────
# Thư mục lưu dữ liệu user containers trên host
# Phải có quyền write, khuyến nghị: NVMe/SSD
# Dung lượng: 250GB+ (phục vụ ~40-50 containers)
DATA_DIR=/data/users

# ─── PORT & SERVICE ───────────────────────────────────────────────────────────
# Port mà VPS Worker health check chạy
PORT=3002

# Node.js environment
NODE_ENV=production

# Enable debug logs (true/false)
DEBUG=false

# ─── CLOUDFLARE DNS (Traefik Wildcard SSL) ────────────────────────────────────
# Email tài khoản Cloudflare (dùng cho ACME Let's Encrypt)
CF_EMAIL=your-email@example.com

# API Token từ Cloudflare
# Tạo tại: Cloudflare Dashboard → My Profile → API Tokens
# Cần permissions: Edit zone DNS + Read zone settings
# Dùng cho DNS challenge (*.openclaw.ai)
CF_DNS_API_TOKEN=your-cloudflare-api-token-here

# ═══════════════════════════════════════════════════════════════════════════════
# QUICK SETUP CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════
#
# [ ] 1. Copy file này: cp .env.example .env
# [ ] 2. Railway: Lấy Backend API URL, Redis URL
# [ ] 3. Railway: Tạo VPS_WORKER_SECRET (random 32+ chars)
# [ ] 4. Cloudflare: Tạo API Token với DNS edit permission
# [ ] 5. Update tất cả giá trị ở trên trong .env
# [ ] 6. Deploy: docker-compose up -d
# [ ] 7. Check: docker-compose logs -f vps-worker
#
# ═══════════════════════════════════════════════════════════════════════════════
