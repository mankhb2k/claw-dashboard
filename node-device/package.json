{
  "name": "@openclaw/node-device",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw companion node desktop app (Electron)",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "start": "electron .",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:win": "pnpm run build && electron-builder --win",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test:pairing": "node scripts/test-pairing-flow.mjs",
    "test:pairing:electron": "node scripts/test-pairing-electron.mjs"
  },
  "dependencies": {
    "openclaw": "latest",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@types/node": "^24.0.0",
    "electron": "^40.10.2",
    "electron-builder": "^26.0.12",
    "preact": "^10.27.2",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "extends": "./electron-builder.yml"
  },
  "engines": {
    "node": ">=22.19"
  },
  "packageManager": "pnpm@9.15.9"
}
