{
  "typescript.tsdk": "studio/node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.tsserver.watchOptions": {
    "excludeDirectories": ["**/backend/node_modules"]
  },
  "search.exclude": {
    "**/backend/node_modules": true
  },

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [
    { "directory": "studio/apps/web", "changeProcessCWD": true },
    { "directory": "studio/apps/api", "changeProcessCWD": true }
  ]
}
