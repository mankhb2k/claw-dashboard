DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=<random 32 bytes>
# Public URL of this API. Must use the same hostname+port the browser uses for API calls
# (e.g. match NEXT_PUBLIC_API_URL on the frontend: both localhost:3001 or both 127.0.0.1:3001).
# Mixing localhost and 127.0.0.1 breaks Google OAuth (state_mismatch).
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Internal worker auth
VPS_WORKER_SECRET=<random secret>
# 32-byte key for encrypting per-project env secrets.
# Supports base64 (recommended) or 64-char hex.
PROJECT_ENV_MASTER_KEY=<base64-32-byte-key>

# AES-256-GCM at-rest encryption for project_secrets (gateway token, model API keys)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROJECT_SECRETS_MASTER_KEY=<64 hex chars>

# App
PORT=3001
NODE_ENV=development
# Optional: pino log level (fatal, error, warn, info, debug, trace)
# LOG_LEVEL=info
# Public host label for per-project URLs: https://<slug>.<APP_DOMAIN> (no scheme)
APP_DOMAIN=clawsandbox.cloud
# Docker image for user OpenClaw containers (required for POST /api/projects in production)
OPENCLAW_IMAGE=ghcr.io/yourorg/openclaw:latest