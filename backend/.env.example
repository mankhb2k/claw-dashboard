# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/openclaw

# JWT (required in production)
JWT_SECRET=change-me-to-long-random-string
# Access token TTL in seconds (default 900)
JWT_ACCESS_SECONDS=900
# Refresh token lifetime in days (default 7)
JWT_REFRESH_DAYS=7

# CORS / server
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
# LOG_LEVEL=debug

# AES-256-GCM for project_secrets at rest
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROJECT_SECRETS_MASTER_KEY=

# Optional seed (prisma db seed)
# SEED_USER_EMAIL=dev@example.com
# SEED_USER_PASSWORD=devpassword123
