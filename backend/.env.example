# Dev trên host: npm run docker:deps → npx prisma migrate deploy → npm run dev
DATABASE_URL=postgresql://postgres:password@localhost:5432/openclaw

# Bắt buộc đổi JWT_SECRET trên production
JWT_SECRET=change-me-to-long-random-string
JWT_ACCESS_SECONDS=900
JWT_REFRESH_DAYS=7

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# Connect — Google Drive & Google Calendar (OAuth Web client trên Google Cloud Console)
# Bật APIs: Google Drive API + Google Calendar API
# Redirect URI phải khớp chính xác: http://localhost:3001/api/connectors/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/connectors/oauth/callback

# Phase 2 — Docker spawn (cần Docker Desktop đang chạy)
OPENCLAW_IMAGE=clawsaas-worker:1.0.3
# OPENCLAW_IMAGE=clawsaas-worker:local
# Thư mục host: data/projects/{projectId}/ → mount /home/node/.openclaw (openclaw.json + workspace)
# OPENCLAW_DATA_ROOT=./data/projects
APP_DOMAIN=localhost
# Chờ gateway /healthz sau start/spawn (mặc định 60s — quá hạn → lỗi + spawn lại)
OPENCLAW_SPAWN_TIMEOUT_MS=60000
OPENCLAW_HEALTH_INTERVAL_MS=2000
OPENCLAW_HEALTH_FETCH_TIMEOUT_MS=3000

# Self-host — user mặc định (tự tạo/cập nhật khi backend start hoặc `npx prisma db seed`)
# Đổi mật khẩu: sửa env rồi restart backend (user khác đăng ký qua /api/auth/register vẫn giữ nguyên)
SELF_HOST_USER_LOGIN=admin
SELF_HOST_USER_PASSWORD=admin123
# SELF_HOST_USER_NAME=Admin
# Alias cũ (vẫn đọc được): SEED_USER_LOGIN, SEED_USER_PASSWORD
