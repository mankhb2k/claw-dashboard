generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Phase 1 OSS control plane — user tự host gateway; không billing / container / heavy jobs.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects       Project[]
  refreshTokens  RefreshToken[]

  @@map("users")
}

/// Refresh token rotation (opaque); lưu hash, không lưu raw.
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Project {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  /// URL-safe slug duy nhất toàn cục (dùng trong path / dashboard).
  slug         String           @unique
  displayName  String           @map("display_name")
  /// Gợi ý nơi user mount OpenClaw (hiển thị / export, không bắt buộc).
  syncPathHint String?          @map("sync_path_hint") @db.Text
  lifecycle    ProjectLifecycle @default(ACTIVE)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceRevisions WorkspaceRevision[]
  secrets            ProjectSecret[]

  @@index([userId])
  @@map("projects")
}

enum ProjectLifecycle {
  ACTIVE
  ARCHIVED
}

/// Mỗi lần save workspace (bundle file path → nội dung text) tạo một revision.
model WorkspaceRevision {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  /// Tăng dần theo project (1, 2, 3…).
  sequence  Int      @map("sequence")
  /// JSON: { "AGENTS.md": "...", "SOUL.md": "...", ... }
  filesJson Json     @map("files_json")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sequence])
  @@index([projectId, createdAt])
  @@map("workspace_revisions")
}

/// Bí mật per-project (API keys, token kênh) — ciphertext base64 từ SecretCryptoService.
model ProjectSecret {
  id         String @id @default(cuid())
  projectId  String @map("project_id")
  secretKey  String @map("secret_key") @db.VarChar(128)
  payloadEnc String @map("payload_enc") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, secretKey], map: "uq_project_secret_key")
  @@index([projectId])
  @@map("project_secrets")
}
