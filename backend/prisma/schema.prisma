generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Self-host: `login` là email hoặc username (unique), không xác thực email.
model User {
  id           String   @id @default(cuid())
  login        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  projects      Project[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Một user ≈ một project (self-host MVP).
model Project {
  id            String        @id @default(cuid())
  userId        String        @unique @map("user_id")
  displayName   String        @map("display_name")
  subdomain     String        @unique
  containerName String?       @map("container_name")
  containerId   String?       @map("container_id")
  hostPort      Int?          @map("host_port")
  gatewayToken  String?       @map("gateway_token")
  volumeName    String?       @map("volume_name")
  syncPathHint  String?       @map("sync_path_hint")
  status        ProjectStatus @default(CREATING)
  errorMessage  String?       @map("error_message")
  lastActiveAt  DateTime      @default(now()) @map("last_active_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceRevisions   WorkspaceRevision[]
  projectChannels      ProjectChannel[]
  projectProviderKeys  ProjectProviderKey[]
  projectSkills        ProjectSkill[]
  projectAgents        ProjectAgent[]

  @@map("projects")
}

/// Template khởi tạo agent (global catalog).
model AgentTemplate {
  slug              String   @id
  name              String
  description       String   @db.Text
  avatar            String
  vibe              String
  defaultModel      String   @map("default_model")
  toolsProfile      String   @map("tools_profile")
  sandboxEnabled    Boolean  @default(false) @map("sandbox_enabled")
  bootstrapIdentity String   @map("bootstrap_identity") @db.Text
  bootstrapSoul     String   @map("bootstrap_soul") @db.Text
  bootstrapAgents   String   @map("bootstrap_agents") @db.Text
  sortOrder         Int      @default(0) @map("sort_order")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("agent_templates")
}

/// Agent user tạo — sync `workspace-{slug}/` + `openclaw.json` `agents.list` (slug ≠ `main`).
model ProjectAgent {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  slug          String
  name          String
  description   String    @db.Text
  avatar        String
  formData      Json      @map("form_data")
  enabled       Boolean   @default(false)
  isDefault     Boolean   @default(false) @map("is_default")
  lastSyncedAt  DateTime? @map("last_synced_at")
  lastSyncError String?   @map("last_sync_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("project_agents")
}

/// Skill user tạo — sync vào `<workspace>/skills/<slug>/SKILL.md` cho OpenClaw.
model ProjectSkill {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  slug          String
  name          String
  description   String    @db.Text
  heading       String?
  bodyMarkdown  String    @default("") @map("body_markdown") @db.Text
  enabled       Boolean   @default(false)
  lastSyncedAt  DateTime? @map("last_synced_at")
  lastSyncError String?   @map("last_sync_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("project_skills")
}

/// API key model provider (OpenAI, Gemini, …) — sync vào `openclaw.json` (`env` + `agents.defaults.model`).
model ProjectProviderKey {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  providerId   String    @map("provider_id")
  envKey       String    @map("env_key")
  label        String?
  ciphertext   String    @db.Text
  enabled      Boolean   @default(true)
  defaultModel String?   @map("default_model")
  lastTestedAt DateTime? @map("last_tested_at")
  lastTestOk   Boolean?  @map("last_test_ok")
  lastError    String?   @map("last_error")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, providerId])
  @@index([projectId])
  @@map("project_provider_keys")
}

/// Một kênh OpenClaw trên project (MVP: 1 account / 1 channelId).
model ProjectChannel {
  id               String                  @id @default(cuid())
  projectId        String                  @map("project_id")
  channelId        String                  @map("channel_id")
  enabled          Boolean                 @default(false)
  connectionStatus ChannelConnectionStatus @default(DISCONNECTED) @map("connection_status")
  config           Json                    @default("{}")
  lastError        String?                 @map("last_error")
  lastTestedAt     DateTime?               @map("last_tested_at")
  lastSyncedAt     DateTime?               @map("last_synced_at")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  project Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secrets ProjectChannelSecret[]

  @@unique([projectId, channelId])
  @@index([projectId])
  @@map("project_channels")
}

model ProjectChannelSecret {
  id               String   @id @default(cuid())
  projectChannelId String   @map("project_channel_id")
  secretKey        String   @map("secret_key")
  ciphertext       String   @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  projectChannel ProjectChannel @relation(fields: [projectChannelId], references: [id], onDelete: Cascade)

  @@unique([projectChannelId, secretKey])
  @@map("project_channel_secrets")
}

enum ChannelConnectionStatus {
  DISCONNECTED
  CONFIGURED
  CONNECTED
  NEEDS_REAUTH
  ERROR
}

/// Snapshot cấu hình/workspace từ dashboard; file thật sync xuống volume project.
model WorkspaceRevision {
  id        String                  @id @default(cuid())
  projectId String                  @map("project_id")
  kind      WorkspaceRevisionKind
  payload   Json
  createdAt DateTime                @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("workspace_revisions")
}

enum WorkspaceRevisionKind {
  OPENCLAW_JSON
  WORKSPACE_BUNDLE
}

enum ProjectStatus {
  CREATING
  STARTING
  RUNNING
  STOPPED
  ERROR
}
