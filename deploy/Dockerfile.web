# Build context: repo root (monorepo)
# docker compose -f deploy/docker-compose.yml build web

FROM node:24-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
WORKDIR /repo

FROM base AS build
ARG NEXT_PUBLIC_API_URL=http://localhost:8387
ARG API_INTERNAL_URL=http://api:8387
ARG NEXT_PUBLIC_MOCK_API=false

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV API_INTERNAL_URL=$API_INTERNAL_URL
ENV NEXT_PUBLIC_MOCK_API=$NEXT_PUBLIC_MOCK_API

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/
COPY packages/workspace-sync/package.json packages/workspace-sync/
RUN pnpm install --frozen-lockfile --ignore-scripts --filter @claw-dashboard/web...

COPY packages/shared packages/shared
COPY packages/workspace-sync packages/workspace-sync
COPY scripts/load-monorepo-env.mjs scripts/load-monorepo-env.mjs
RUN pnpm --filter @claw-dashboard/shared build && pnpm --filter @claw-dashboard/workspace-sync build

COPY apps/web apps/web
WORKDIR /repo/apps/web
RUN pnpm run build

FROM node:24-alpine AS runner
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
ARG API_INTERNAL_URL=http://api:8387
WORKDIR /repo/apps/web
ENV NODE_ENV=production
ENV PORT=8386
ENV HOSTNAME=0.0.0.0
ENV API_INTERNAL_URL=$API_INTERNAL_URL

COPY --from=build /repo /repo

EXPOSE 8386

CMD ["pnpm", "start"]
