{
  "name": "@claw-dashboard/api",
  "version": "0.1.0-auth",
  "description": "OpenClaw SaaS backend — JWT auth (register, login, refresh, me)",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "predev": "pnpm --filter @claw-dashboard/runtime-contracts --filter @claw-dashboard/control-plane-core --filter @claw-dashboard/clawhub-client run build",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:ci": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:chat-upstream": "node scripts/test-chat-upstream.mjs",
    "test:chat-send": "node scripts/test-chat-send.mjs",
    "cleanup:chat-attachments": "node scripts/chat-attachments-cleanup.mjs",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "docker:deps": "docker compose -f ../../deploy/docker-compose.deps.yml up -d --remove-orphans",
    "docker:reset": "docker compose -f ../../deploy/docker-compose.deps.yml down -v --remove-orphans && docker compose -f ../../deploy/docker-compose.deps.yml up -d --remove-orphans"
  },
  "dependencies": {
    "@claw-dashboard/control-plane-core": "workspace:*",
    "@claw-dashboard/database": "workspace:*",
    "@claw-dashboard/runtime-contracts": "workspace:*",
    "@claw-dashboard/runtime-oss": "workspace:*",
    "@claw-dashboard/shared": "workspace:*",
    "@claw-dashboard/workspace-sync": "workspace:*",
    "@claw-dashboard/clawhub-client": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "nanoid": "^5.1.9",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/supertest": "^7.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/../../packages/shared/src",
      "<rootDir>/../../packages/workspace-sync/src"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(nanoid)/)"
    ],
    "moduleNameMapper": {
      "^@claw-dashboard/workspace-sync$": "<rootDir>/../../packages/workspace-sync/src/index.ts",
      "^@claw-dashboard/clawhub-client$": "<rootDir>/../../packages/clawhub-client/src/index.ts",
      "^@claw-dashboard/shared$": "<rootDir>/../../packages/shared/src/index.ts",
      "^@claw-dashboard/runtime-contracts$": "<rootDir>/../../packages/runtime-contracts/src/index.ts",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
